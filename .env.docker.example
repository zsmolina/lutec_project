# Copie a backend/.env antes de: docker compose up --build
# (docker-compose lee backend/.env vía env_file del servicio backend)

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

MAX_ZIP_SIZE_MB=100
MAX_FORMAP_EXCEL_MB=50
MAX_PDF_COUNT=500
MAX_PDF_SIZE_MB=25
JOB_TTL_HOURS=24

CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
TEMP_DIR=
